generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============ Users & Auth ============

model User {
  id              String   @id @default(cuid())
  email           String?  @unique
  name            String?
  avatar          String?
  walletAddress   String?  @unique
  authProvider    String?  // google, apple, x, email
  authProviderId  String?
  role            String   @default("user") // user, investor, issuer, admin
  kycStatus       String   @default("none") // none, pending, verified, rejected
  creditScore     Int      @default(100)
  riskAccepted    Boolean  @default(false)
  invitedByCode   String?  // the invitation code this user used to join
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  portfolio           PortfolioHolding[]
  investments         Investment[]
  tradeOrders         TradeOrder[]
  chatMessages        ChatMessage[]
  groupMessages       GroupMessage[]
  transactions        Transaction[]
  enterprises         EnterpriseVerification[]
  applications        ProposedApplication[]
  creditHistory       CreditScoreHistory[]
  creditEvents        CreditScoreEvent[]
  governanceProposals GovernanceProposal[]
  governanceVotes     GovernanceVote[]
  notifications       Notification[]
  redemptionQueue     RedemptionQueue[]
  groupMembers        GroupMember[]
  invitationCodes     InvitationCode[]  // codes this user generated

  // Community: friends & DM
  friendshipsRequested Friendship[]              @relation("FriendshipRequester")
  friendshipsReceived  Friendship[]              @relation("FriendshipAddressee")
  conversationLinks    ConversationParticipant[]
  directMessages       DirectMessage[]

  @@index([email])
  @@index([walletAddress])
}

model InvitationCode {
  id          String    @id @default(cuid())
  code        String    @unique                // e.g. "LOKA-A1B2C3"
  createdById String                           // user who created the code
  usedById    String?                          // user who redeemed the code
  usedAt      DateTime?                        // when it was used
  maxUses     Int       @default(1)            // how many times this code can be used
  useCount    Int       @default(0)            // current usage count
  isActive    Boolean   @default(true)         // admin can disable
  expiresAt   DateTime?                        // optional expiry
  createdAt   DateTime  @default(now())

  createdBy   User      @relation(fields: [createdById], references: [id])

  @@index([code])
  @@index([createdById])
}

// ============ Projects & Fundraising ============

model Project {
  id              String   @id @default(cuid())
  title           String
  subtitle        String?
  category        String   // Compute, SaaS, E-commerce
  issuer          String
  issuerLogo      String?
  coverImage      String?
  description     String?
  useOfFunds      String?
  faceValue       Float    @default(100)
  askPrice        Float    @default(100)
  apy             Float
  durationDays    Int
  creditScore     Int      @default(700)
  status          String   @default("Fundraising") // Fundraising, Ending Soon, Sold Out, Failed, Funded
  targetAmount    Float
  raisedAmount    Float    @default(0)
  backersCount    Int      @default(0)
  remainingCap    Float    @default(0)
  coverageRatio   Float    @default(0)
  verifiedSource  String?
  endDate         DateTime?  // 募资截止日期 = createdAt + durationDays
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  monthlyRevenue    MonthlyRevenue[]
  investments       Investment[]
  tradeOrders       TradeOrder[]
  groupChat         GroupChat?
  repayments        RepaymentSchedule[]
  collaterals       Collateral[]
  liquidations      LiquidationEvent[]

  @@index([status])
  @@index([category])
}

model MonthlyRevenue {
  id        String  @id @default(cuid())
  projectId String
  month     String
  amount    Float
  project   Project @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

model Investment {
  id          String   @id @default(cuid())
  userId      String
  projectId   String
  amount      Float
  shares      Float
  status      String   @default("active") // active, matured, sold, defaulted
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@index([userId])
  @@index([projectId])
}

// ============ Trading ============

model TradeOrder {
  id                String   @id @default(cuid())
  projectId         String
  sellerId          String
  buyerId           String?
  listPrice         Float
  originalPrice     Float
  shares            Float
  totalValue        Float
  expectedReturn    Float
  expectedYield     Float
  status            String   @default("Listed") // Listed, Sold, Cancelled
  listedAt          DateTime @default(now())
  soldAt            DateTime?

  project Project @relation(fields: [projectId], references: [id])
  seller  User    @relation(fields: [sellerId], references: [id])

  @@index([projectId])
  @@index([sellerId])
  @@index([status])
}

// ============ Treasury ============

model TreasurySnapshot {
  id                String   @id @default(cuid())
  tvl               Float
  collateralRatio   Float
  treasuryRevenue   Float
  tBillsPercent     Float
  liquidityPercent  Float
  operationsPercent Float
  lastPoR           DateTime
  createdAt         DateTime @default(now())
}

// ============ Transactions ============

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  type      String   // MINT, REDEEM, INTEREST, DEPOSIT, WITHDRAW
  amount    Float
  asset     String   // AIUSD, USDC, etc.
  status    String   @default("PENDING") // PENDING, COMPLETED, FAILED, QUEUED
  txHash    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
}

// ============ Portfolio ============

model PortfolioHolding {
  id          String   @id @default(cuid())
  userId      String
  asset       String
  amount      Float
  avgCost     Float    @default(0)
  currentApy  Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, asset])
  @@index([userId])
}

// ============ Groups & Messaging ============

model GroupChat {
  id          String   @id @default(cuid())
  projectId   String?  @unique
  name        String
  bio         String?
  avatar      String?
  fundedAmount Float   @default(0)
  apy         Float    @default(0)
  createdAt   DateTime @default(now())

  project  Project?       @relation(fields: [projectId], references: [id])
  messages GroupMessage[]
  members  GroupMember[]
}

model GroupMember {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  role       String   @default("member") // member, issuer, agent
  joinedAt   DateTime @default(now())
  lastReadAt DateTime @default(now())

  group GroupChat @relation(fields: [groupId], references: [id])
  user  User     @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
}

model GroupMessage {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  content   String
  role      String   @default("investor") // issuer, investor, agent
  createdAt DateTime @default(now())

  group GroupChat @relation(fields: [groupId], references: [id])
  user  User     @relation(fields: [userId], references: [id])

  @@index([groupId])
}

// ============ Chat / AI ============

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  sessionId String?  // groups messages into conversations
  role      String   // user, assistant, system
  content   String
  agentId   String?  // which agent responded
  metadata  String?  // JSON string for structured data
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, sessionId])
  @@index([agentId])
}

// ============ Enterprise Verification (Phase 5) ============

model EnterpriseVerification {
  id              String   @id @default(cuid())
  userId          String
  companyName     String
  country         String
  registrationNo  String?
  licenseDoc      String?  // file URL
  uboName         String?
  uboIdDoc        String?  // file URL
  step            Int      @default(1) // 1-4 verification steps
  status          String   @default("pending") // pending, in_review, verified, rejected
  creditAwarded   Int      @default(0)
  sbtMinted       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user         User                  @relation(fields: [userId], references: [id])
  applications ProposedApplication[]

  @@index([userId])
  @@index([status])
}

model ProposedApplication {
  id                  String   @id @default(cuid())
  enterpriseId        String
  userId              String
  projectName         String
  description         String?
  category            String
  monthlyRevenue      Float
  requestedAmount     Float
  proposedApy         Float
  durationDays        Int
  collateralType      String?
  collateralValue     Float    @default(0)
  revenueSource       String?  // stripe, paypal, quickbooks
  revenueVerified     Boolean  @default(false)
  status              String   @default("draft") // draft, submitted, in_review, approved, rejected
  reviewNotes         String?
  aiScore             Float?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  enterprise EnterpriseVerification @relation(fields: [enterpriseId], references: [id])
  user       User                   @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

// ============ Credit Score (Phase 6) ============

model CreditScoreHistory {
  id        String   @id @default(cuid())
  userId    String
  score     Int
  tier      String   // Tier1, Tier2, Tier3
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model CreditScoreEvent {
  id        String   @id @default(cuid())
  userId    String
  eventType String   // enterprise_verify, fundraise_complete, repayment, late_payment, investment, kyc, etc.
  delta     Int      // + or - score change
  reason    String
  refId     String?  // reference to related entity (projectId, investmentId, etc.)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([eventType])
}

// ============ Repayment (Phase 7) ============

model RepaymentSchedule {
  id            String   @id @default(cuid())
  projectId     String
  periodNumber  Int      // 1, 2, 3...
  dueDate       DateTime
  principalDue  Float
  interestDue   Float
  totalDue      Float
  paidAmount    Float    @default(0)
  status        String   @default("upcoming") // upcoming, due, paid, overdue, defaulted
  paidAt        DateTime?
  createdAt     DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])

  @@unique([projectId, periodNumber])
  @@index([projectId])
  @@index([status])
  @@index([dueDate])
}

// ============ Liquidation (Phase 8) ============

model Collateral {
  id          String   @id @default(cuid())
  projectId   String
  type        String   // physical_asset, receivable, deposit, ip_lien
  description String
  value       Float
  status      String   @default("pledged") // pledged, seized, liquidated, released
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project          Project            @relation(fields: [projectId], references: [id])
  liquidationEvents LiquidationEvent[]

  @@index([projectId])
}

model LiquidationEvent {
  id              String   @id @default(cuid())
  projectId       String
  collateralId    String?
  triggerReason   String   // overdue_30, overdue_90, fraud
  recoveredAmount Float    @default(0)
  status          String   @default("initiated") // initiated, in_progress, completed, cancelled
  waterfallTier   String?  // senior, unsecured, equity
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project    Project     @relation(fields: [projectId], references: [id])
  collateral Collateral? @relation(fields: [collateralId], references: [id])

  @@index([projectId])
  @@index([status])
}

// ============ Governance (Phase 9) ============

model GovernanceProposal {
  id          String   @id @default(cuid())
  creatorId   String
  title       String
  description String
  category    String   // parameter_change, treasury_rebalance, fee_adjustment, tier_threshold
  status      String   @default("active") // active, passed, rejected, executed
  forVotes    Float    @default(0)
  againstVotes Float   @default(0)
  quorum      Float    @default(0)
  startsAt    DateTime @default(now())
  endsAt      DateTime
  executedAt  DateTime?
  createdAt   DateTime @default(now())

  creator User              @relation(fields: [creatorId], references: [id])
  votes   GovernanceVote[]

  @@index([status])
  @@index([creatorId])
}

model GovernanceVote {
  id         String   @id @default(cuid())
  proposalId String
  userId     String
  vote       String   // for, against
  weight     Float    // based on portfolio holdings
  createdAt  DateTime @default(now())

  proposal GovernanceProposal @relation(fields: [proposalId], references: [id])
  user     User               @relation(fields: [userId], references: [id])

  @@unique([proposalId, userId])
  @@index([proposalId])
}

// ============ Redemption Queue (Large AIUSD Redemptions) ============

model RedemptionQueue {
  id              String   @id @default(cuid())
  userId          String
  amount          Float    // gross AIUSD amount
  fee             Float    // redemption fee
  netAmount       Float    // net USDC to receive
  status          String   @default("queued") // queued, processing, completed, cancelled
  queuedAt        DateTime @default(now())
  processAfter    DateTime // T+7 processing date
  completedAt     DateTime?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([processAfter])
}

// ============ Notifications ============

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // investment, repayment, liquidation, governance, credit, system
  title     String
  body      String
  refType   String?  // project, proposal, trade, etc.
  refId     String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, read])
  @@index([userId, createdAt])
}

// ============ Idempotency ============

model IdempotencyKey {
  id        String   @id @default(cuid())
  key       String   @unique
  userId    String
  response  String   // JSON stringified response
  createdAt DateTime @default(now())

  @@index([key])
  @@index([createdAt])
}

// ============ Community: Friendship ============

model Friendship {
  id          String   @id @default(cuid())
  requesterId String
  addresseeId String
  status      String   @default("pending") // pending, accepted, blocked
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id])
  addressee User @relation("FriendshipAddressee", fields: [addresseeId], references: [id])

  @@unique([requesterId, addresseeId])
  @@index([addresseeId])
}

// ============ Community: DM Conversations ============

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     DirectMessage[]
}

model ConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
}

model DirectMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
}
