# Database (PostgreSQL for production)
DATABASE_URL="postgresql://user:password@host:5432/moltcash?sslmode=require"

# Server
PORT=3003

# CORS (comma-separated origins)
CORS_ORIGINS="https://moltcash.com,https://www.moltcash.com,http://localhost:3001"

# Privy Auth (get from dashboard.privy.io → Settings → Keys)
PRIVY_APP_ID="your-privy-app-id"
PRIVY_APP_SECRET="your-privy-app-secret"
PRIVY_VERIFICATION_KEY=""
